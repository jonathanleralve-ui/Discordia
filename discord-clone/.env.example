# Copy this file to .env and adjust as needed if running the app directly
# with `npm start` against a locally running Postgres (instead of docker compose).

PORT=3000
JWT_SECRET=dev-secret-change-me-in-production

PGHOST=localhost
PGPORT=5432
PGUSER=chatter
PGPASSWORD=chatter
PGDATABASE=chatter

# Alternatively, set a single connection string instead of the PG* vars above:
# DATABASE_URL=postgres://chatter:chatter@localhost:5432/chatter
